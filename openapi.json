{
  "openapi": "3.0.3",
  "info": {
    "title": "Eburon AI Live Audio API",
    "description": "Comprehensive real-time audio system with Eburon AI Live Audio API. Provides instant translation between 80+ languages with voice input and output. Features Speech-to-Text (STT), Text-to-Speech (TTS), system prompt management, real-time audio streaming, translation, and conversational AI capabilities.",
    "version": "1.0.0",
    "contact": {
      "name": "Eburon AI Support",
      "email": "support@eburon.ai"
    },
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Development server"
    },
    {
      "url": "https://translation-service.example.com",
      "description": "Production server"
    }
  ],
  "paths": {
    "/api/audio/stream": {
      "post": {
        "summary": "Start real-time audio streaming",
        "description": "Initiate real-time bidirectional audio streaming with Eburon AI STT and TTS",
        "tags": ["Audio Streaming"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "sampleRate": {
                    "type": "integer",
                    "description": "Audio sample rate in Hz",
                    "example": 16000
                  },
                  "channels": {
                    "type": "integer",
                    "description": "Number of audio channels",
                    "example": 1
                  },
                  "voice": {
                    "type": "string",
                    "description": "TTS voice name",
                    "example": "Aoede"
                  }
                },
                "required": ["sampleRate"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Streaming session established",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StreamingSession"
                }
              }
            }
          }
        }
      }
    },
    "/api/stt/transcribe": {
      "post": {
        "summary": "Speech-to-Text transcription",
        "description": "Convert audio input to text using advanced STT",
        "tags": ["Speech-to-Text"],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "audio": {
                    "type": "string",
                    "format": "binary",
                    "description": "Audio file to transcribe (WAV, MP3, M4A)"
                  },
                  "language": {
                    "type": "string",
                    "description": "Source language code (optional, auto-detected if not provided)",
                    "example": "en"
                  },
                  "enhanced": {
                    "type": "boolean",
                    "description": "Use enhanced transcription model",
                    "example": true
                  }
                },
                "required": ["audio"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transcription successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranscriptionResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/tts/synthesize": {
      "post": {
        "summary": "Text-to-Speech synthesis",
        "description": "Convert text to natural-sounding speech",
        "tags": ["Text-to-Speech"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "text": {
                    "type": "string",
                    "description": "Text to synthesize",
                    "example": "Hello, how are you today?"
                  },
                  "voice": {
                    "type": "string",
                    "description": "Voice name for synthesis",
                    "example": "Aoede"
                  },
                  "language": {
                    "type": "string",
                    "description": "Target language code",
                    "example": "en"
                  },
                  "speed": {
                    "type": "number",
                    "format": "float",
                    "description": "Speech speed (0.5-2.0)",
                    "example": 1.0
                  }
                },
                "required": ["text"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Speech synthesis successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SynthesisResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/prompt/system": {
      "get": {
        "summary": "Get system prompt",
        "description": "Retrieve current system prompt configuration",
        "tags": ["System Prompt"],
        "responses": {
          "200": {
            "description": "System prompt retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SystemPrompt"
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Update system prompt",
        "description": "Update the AI system prompt for behavior control",
        "tags": ["System Prompt"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "prompt": {
                    "type": "string",
                    "description": "New system prompt text",
                    "example": "You are a helpful AI assistant..."
                  },
                  "temperature": {
                    "type": "number",
                    "format": "float",
                    "description": "AI model temperature (0-1)",
                    "example": 0.7
                  }
                },
                "required": ["prompt"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "System prompt updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SystemPrompt"
                }
              }
            }
          }
        }
      }
    },
    "/api/conversation/chat": {
      "post": {
        "summary": "Send chat message",
        "description": "Send a message to the AI and receive response",
        "tags": ["Conversation"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": {
                    "type": "string",
                    "description": "User message",
                    "example": "Tell me about artificial intelligence"
                  },
                  "context": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "role": { "type": "string" },
                        "content": { "type": "string" }
                      }
                    },
                    "description": "Conversation context"
                  }
                },
                "required": ["message"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Chat response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/translate": {
      "post": {
        "summary": "Translate text or audio",
        "description": "Translate text or audio between languages",
        "tags": ["Translation"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "input": {
                    "type": "string",
                    "description": "Text to translate or audio data"
                  },
                  "sourceLanguage": {
                    "type": "string",
                    "description": "Source language code",
                    "example": "en"
                  },
                  "targetLanguage": {
                    "type": "string",
                    "description": "Target language code",
                    "example": "es"
                  },
                  "type": {
                    "type": "string",
                    "enum": ["text", "audio"],
                    "description": "Input type",
                    "example": "text"
                  }
                },
                "required": ["input", "targetLanguage"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Translation successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranslationResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/languages": {
      "get": {
        "summary": "Get supported languages",
        "description": "Retrieve list of supported languages for translation",
        "tags": ["Languages"],
        "responses": {
          "200": {
            "description": "List of supported languages",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LanguagesResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/config": {
      "get": {
        "summary": "Get current configuration",
        "description": "Retrieve current translation service configuration",
        "tags": ["Configuration"],
        "responses": {
          "200": {
            "description": "Current configuration",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Configuration"
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Update configuration",
        "description": "Update translation service configuration",
        "tags": ["Configuration"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConfigurationUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Configuration updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Configuration"
                }
              }
            }
          },
          "400": {
            "description": "Invalid configuration",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/translate/stream": {
      "post": {
        "summary": "Real-time translation streaming",
        "description": "Establish WebSocket connection for real-time audio translation streaming",
        "tags": ["Translation"],
        "responses": {
          "101": {
            "description": "WebSocket connection established"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/server/start": {
      "post": {
        "summary": "Start the server",
        "description": "Start the Eburon AI Live Audio server and initialize WebSocket connections",
        "tags": ["Server Control"],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "autoConnect": {
                    "type": "boolean",
                    "description": "Automatically connect to WebSocket on start",
                    "example": true
                  },
                  "config": {
                    "type": "object",
                    "description": "Server configuration options",
                    "properties": {
                      "voice": { "type": "string", "example": "Aoede" },
                      "sampleRate": { "type": "integer", "example": 16000 },
                      "temperature": { "type": "number", "example": 0.3 }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Server started successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServerStatus"
                }
              }
            }
          },
          "500": {
            "description": "Failed to start server",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/server/stop": {
      "post": {
        "summary": "Stop the server",
        "description": "Stop the Eburon AI Live Audio server and close all connections",
        "tags": ["Server Control"],
        "responses": {
          "200": {
            "description": "Server stopped successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServerStatus"
                }
              }
            }
          }
        }
      }
    },
    "/api/server/status": {
      "get": {
        "summary": "Get server status",
        "description": "Get current server status and connection information",
        "tags": ["Server Control"],
        "responses": {
          "200": {
            "description": "Server status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServerStatus"
                }
              }
            }
          }
        }
      }
    },
    "/api/connection/connect": {
      "post": {
        "summary": "Connect to WebSocket",
        "description": "Establish WebSocket connection to the Eburon AI service",
        "tags": ["Connection Management"],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "config": {
                    "type": "object",
                    "description": "Connection configuration",
                    "properties": {
                      "voice": { "type": "string", "example": "Aoede" },
                      "sampleRate": { "type": "integer", "example": 16000 },
                      "targetLanguage": { "type": "string", "example": "auto" }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Connection established",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConnectionStatus"
                }
              }
            }
          },
          "500": {
            "description": "Connection failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/connection/disconnect": {
      "post": {
        "summary": "Disconnect from WebSocket",
        "description": "Close WebSocket connection and cleanup resources",
        "tags": ["Connection Management"],
        "responses": {
          "200": {
            "description": "Disconnected successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConnectionStatus"
                }
              }
            }
          }
        }
      }
    },
    "/api/connection/status": {
      "get": {
        "summary": "Get connection status",
        "description": "Get current WebSocket connection status and statistics",
        "tags": ["Connection Management"],
        "responses": {
          "200": {
            "description": "Connection status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConnectionStatus"
                }
              }
            }
          }
        }
      }
    },
    "/api/health": {
      "get": {
        "summary": "Health check",
        "description": "Check if the Eburon AI Live Audio service is running and accessible",
        "tags": ["Health"],
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          },
          "503": {
            "description": "Service unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/audio/microphone/start": {
      "post": {
        "summary": "Start microphone recording",
        "description": "Start recording audio from the microphone for real-time processing",
        "tags": ["Audio Streaming"],
        "responses": {
          "200": {
            "description": "Microphone started successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AudioResponse"
