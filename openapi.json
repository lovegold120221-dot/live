                "schema": {
                  "$ref": "#/components/schemas/VideoResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/video/screen/stop": {
      "post": {
        "summary": "Stop screen sharing",
        "description": "Stop sharing the screen content",
        "tags": ["Video Streaming"],
        "responses": {
          "200": {
            "description": "Screen sharing stopped successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VideoResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/conversation/message": {
      "post": {
        "summary": "Send message to AI",
        "description": "Send a text message to the AI for processing",
        "tags": ["Conversation"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": {
                    "type": "string",
                    "description": "Message to send to the AI",
                    "example": "Hello, how are you?"
                  }
                },
                "required": ["message"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/config/language": {
      "put": {
        "summary": "Update target language",
        "description": "Update the target language for translation",
        "tags": ["Configuration"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "language": {
                    "type": "string",
                    "description": "Target language code",
                    "example": "es"
                  }
                },
                "required": ["language"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Language updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/config/voice": {
      "put": {
        "summary": "Update voice settings",
        "description": "Update the voice configuration for TTS",
        "tags": ["Configuration"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "voice": {
                    "type": "string",
                    "description": "Voice name",
                    "example": "Aoede"
                  }
                },
                "required": ["voice"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Voice updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/config/prompt": {
      "put": {
        "summary": "Update system prompt",
        "description": "Update the system prompt for AI behavior",
        "tags": ["Configuration"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "prompt": {
                    "type": "string",
                    "description": "System prompt text",
                    "example": "You are a helpful AI assistant."
                  }
                },
                "required": ["prompt"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Prompt updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "StreamingSession": {
        "type": "object",
        "properties": {
          "sessionId": {
            "type": "string",
            "description": "Unique streaming session identifier",
            "example": "session_abc123"
          },
          "websocketUrl": {
            "type": "string",
            "format": "uri",
            "description": "WebSocket URL for real-time communication",
            "example": "wss://api.example.com/ws/session_abc123"
          },
          "sampleRate": {
            "type": "integer",
            "description": "Audio sample rate for the session",
            "example": 16000
          },
          "channels": {
            "type": "integer",
            "description": "Number of audio channels",
            "example": 1
          },
          "voice": {
            "type": "string",
            "description": "TTS voice for the session",
            "example": "Aoede"
          }
        }
      },
      "TranscriptionResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "text": {
            "type": "string",
            "description": "Transcribed text",
            "example": "Hello, how are you today?"
          },
          "confidence": {
            "type": "number",
            "format": "float",
            "description": "Transcription confidence score (0-1)",
            "example": 0.98
          },
          "language": {
            "type": "string",
            "description": "Detected language code",
            "example": "en"
          },
          "duration": {
            "type": "number",
            "format": "float",
            "description": "Audio duration in seconds",
            "example": 3.5
          }
        }
      },
      "SynthesisResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "audioUrl": {
            "type": "string",
            "format": "uri",
            "description": "URL to generated audio file",
            "example": "/api/audio/synthesized_xyz789.wav"
          },
          "text": {
            "type": "string",
            "description": "Original text that was synthesized",
            "example": "Hello, how are you today?"
          },
          "voice": {
            "type": "string",
            "description": "Voice used for synthesis",
            "example": "Aoede"
          },
          "duration": {
            "type": "number",
            "format": "float",
            "description": "Generated audio duration in seconds",
            "example": 2.1
          }
        }
      },
      "SystemPrompt": {
        "type": "object",
        "properties": {
          "prompt": {
            "type": "string",
            "description": "Current system prompt text",
            "example": "You are a helpful AI assistant..."
          },
          "temperature": {
            "type": "number",
            "format": "float",
            "description": "AI model temperature (0-1)",
            "example": 0.7
          },
          "maxTokens": {
            "type": "integer",
            "description": "Maximum response tokens",
            "example": 1000
          },
          "model": {
            "type": "string",
            "description": "AI model being used",
            "example": "eburon-ai-live-audio-preview"
          }
        }
      },
      "ChatResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
