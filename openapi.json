        "responses": {
          "200": {
            "description": "Microphone stopped successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AudioResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/video/camera/start": {
      "post": {
        "summary": "Start camera capture",
